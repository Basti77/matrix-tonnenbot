# tonnenbot env

MATRIX_HOMESERVER=https://matrix.notlegal.space
MATRIX_USER_ID=@tonnenbot:matrix.notlegal.space
MATRIX_ACCESS_TOKEN=CHANGE_ME
MATRIX_DEVICE_ID=TONNENBOT

# Target room (alias or !id). For @tonnenbot, typically the family room.
MATRIX_ROOM=!gmQgUVYNmQFFHVDPlW:matrix.notlegal.space

# AbfallNavi service_id. krwaf = Kreis Gütersloh GEG.
ABFALL_SERVICE=krwaf
ABFALL_CITY=Langenberg
ABFALL_STREET=Schneiderstraße

# Fraktions-IDs, die gemeldet werden sollen.
# 0-4 = Restabfall-Varianten, 8/9 = Papiertonne, 10/11 = Gelbe Tonne
WATCH_FRAKTION_IDS=0,1,2,3,4,8,9,10,11

# Daily check time (local Europe/Berlin)
CHECK_HOUR=15
CHECK_MINUTE=0

# On startup: post immediately (for testing). Set 0 after verification.
POST_ON_STARTUP=1
# On startup: also include today in the check (otherwise only tomorrow).
# Useful for a first test after hours. Leave 0 in production.
STARTUP_FORCE_TODAY=0

LOG_LEVEL=INFO
STATE_DIR=%h/.local/state/tonnenbot
